# Copy to .env and fill in values (never commit .env)

# Required for signed JWT sessions (generate: openssl rand -hex 32)
JWT_SECRET=change-me

# Optional — persistent storage; omit for in-memory demo mode
# MONGODB_URI=mongodb+srv://...

# Optional — lab chat, synthesis parser, experiment briefs (free tier at aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional OpenAI fallback (Gemini is preferred when both are set)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
